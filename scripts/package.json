{
  "name": "21tb-cloud-video-learning",
  "version": "1.0.0",
  "description": "21tb 时光易学平台自动化学习工具 - 登录获取课表 + 启动课程播放",
  "scripts": {
    "login": "node 21tb-login-crawler.js",
    "agent": "node 21tb-login-crawler.js --agent --json",
    "auto": "node 21tb-login-crawler.js --auto",
    "auto:advance": "node 21tb-login-crawler.js --auto --auto-advance",
    "agent:headful": "node 21tb-login-crawler.js --agent --json --headful",
    "agent:entry": "node agent-entry.js"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "dotenv": "^17.4.2",
    "puppeteer": "^24.0.0"
  }
}
